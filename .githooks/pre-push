#!/usr/bin/env bash
# =============================================================================
# pre-push — 分支保护 + 版本号门禁
# =============================================================================
# 1. 禁止 force push 到 main 和 develop
# 2. 推送到 main 前提示确认（生产分支）
# 3. 推送版本 tag 时校验 SemVer 增量策略
#
# Install: git config core.hooksPath .githooks
#
# Env:
#   ALLOW_TAG_REWRITE=1  — allow rewriting an existing tag (dangerous)
# =============================================================================
set -euo pipefail

HOOK_DIR=$(cd "$(dirname "$0")" && pwd)
HOOK_NAME="pre-push"

# shellcheck source=.githooks/lib/common.sh
. "${HOOK_DIR}/lib/common.sh"
# shellcheck source=.githooks/lib/pre-push.sh
. "${HOOK_DIR}/lib/pre-push.sh"

setup_repo_root
load_pushed_refs

if [ "${#PUSHED_REFS[@]}" -eq 0 ]; then
  info "未检测到推送的 refs，跳过检查"
  exit 0
fi

# ---------------------------------------------------------------------------
# 1 & 2. Branch protection
# ---------------------------------------------------------------------------
for ref_line in "${PUSHED_REFS[@]}"; do
  read -r local_ref local_oid remote_ref remote_oid <<< "$ref_line"

  for branch in "${PROTECTED_BRANCHES[@]}"; do
    if echo "$remote_ref" | grep -q "refs/heads/$branch"; then
      if is_non_fast_forward_update "$local_oid" "$remote_oid"; then
        fail "禁止对 ${BOLD}$branch${RESET} 执行 non-fast-forward 更新（等价于 force rewrite）。
请通过 PR 合入，或推送到新分支（feat/*, fix/*）。"
      fi

      if [ "$branch" = "main" ]; then
        echo -e "${YELLOW}[pre-push]${RESET} 即将推送到 ${BOLD}main${RESET}（生产分支）。"
        echo -e "  通常应通过 develop → main 的 PR 合入。"
        echo -e "  如需继续，请在 3 秒内按 Ctrl+C 取消。"
        sleep 3
      fi
    fi
  done
done

# ---------------------------------------------------------------------------
# 3. Version tag gate — delegate to check-version-bump.sh
# ---------------------------------------------------------------------------
VERSION_CHECK_SCRIPT="${REPO_ROOT}/scripts/check-version-bump.sh"

for ref_line in "${PUSHED_REFS[@]}"; do
  read -r local_ref local_oid remote_ref remote_oid <<< "$ref_line"

  if echo "$remote_ref" | grep -qE '^refs/tags/v[0-9]'; then
    TAG_NAME=$(echo "$remote_ref" | sed 's|refs/tags/||')
    TAG_VERSION="${TAG_NAME#v}"

    # Skip deletions
    if is_all_zero_oid "$local_oid"; then
      continue
    fi

    # Block tag rewrites by default (release tags should be immutable).
    if ! is_all_zero_oid "$remote_oid" && [ "$local_oid" != "$remote_oid" ]; then
      if [ "${ALLOW_TAG_REWRITE:-}" != "1" ]; then
        fail "检测到 tag 重写（危险操作，默认禁止）: ${BOLD}${TAG_NAME}${RESET}
  remote: ${remote_oid}
  local : ${local_oid}

如确认需要重写 tag，请显式设置:
  ${BOLD}ALLOW_TAG_REWRITE=1${RESET} git push -f origin \"${TAG_NAME}\""
      fi
      warn "ALLOW_TAG_REWRITE=1 — 放行 tag 重写: ${TAG_NAME}"
    fi

    if [ -f "$VERSION_CHECK_SCRIPT" ]; then
      bash "$VERSION_CHECK_SCRIPT" "$TAG_NAME"
    else
      fail "版本检查脚本不存在: $VERSION_CHECK_SCRIPT"
    fi

    validate_version_files_match_tag "$TAG_NAME" "$TAG_VERSION" "$local_oid"
  fi
done

info "分支保护检查通过 ✓"
