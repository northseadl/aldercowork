#!/usr/bin/env bash
# =============================================================================
# commit-msg — Conventional Commits 格式校验（中文）
# =============================================================================
# 模式: <type>: <subject>
#   type = feat|fix|refactor|perf|docs|style|test|build|ci|chore|revert
#   subject = 至少 2 个字符的描述（中英文均可）
#
# 示例:
#   feat: 新增技能导入功能
#   fix: 修复 Windows 归档解压路径问题
#   ci: 添加 4 平台矩阵构建
#   refactor: 提取 skill.rs 模块
#
# Install: git config core.hooksPath .githooks
# =============================================================================
set -euo pipefail

HOOK_DIR=$(cd "$(dirname "$0")" && pwd)
HOOK_NAME="commit-msg"

# shellcheck source=.githooks/lib/common.sh
. "${HOOK_DIR}/lib/common.sh"

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

# Skip merge commits and fixup/squash commits
if echo "$COMMIT_MSG" | grep -qE '^(Merge |fixup! |squash! |amend! )'; then
  exit 0
fi

# Conventional commit pattern
# type(scope)?: subject  OR  type: subject
PATTERN='^(feat|fix|refactor|perf|docs|style|test|build|ci|chore|revert)(\(.+\))?: .{2,}'

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  fail "提交信息不符合 Conventional Commits 规范。

${BOLD}格式:${RESET} <type>: <subject>

${BOLD}合法的 type:${RESET}
  feat       新功能
  fix        修复 Bug
  refactor   重构（既不修复也不新增功能）
  perf       性能优化
  docs       文档变更
  style      代码格式（不影响逻辑）
  test       测试相关
  build      构建系统或外部依赖
  ci         CI/CD 配置
  chore      杂项（不修改 src 或 test）
  revert     回退

${BOLD}示例:${RESET}
  feat: 新增技能导入功能
  fix: 修复 Windows 归档解压路径问题
  refactor(skill): 提取 skill.rs 模块

${BOLD}你的提交信息:${RESET} $COMMIT_MSG
"
fi

info "格式校验通过 ✓"
